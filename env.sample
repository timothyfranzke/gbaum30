# Stripe API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Consent / analytics — flip to "true" to activate the opt-in consent banner
# and gate analytics scripts behind useConsent().analytics. While "false" the
# consent provider creates NO cookies or localStorage.
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Cloudflare Turnstile (free spam protection for the contact form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Random salt used to hash submitter IP addresses in the contacts audit record
CONTACT_IP_SALT=

# Copy this file to .env.local and replace with your actual keys
# IMPORTANT: Never commit .env.local to version control
